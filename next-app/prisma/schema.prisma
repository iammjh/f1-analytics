// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — MongoDB
//
// KEY DIFFERENCES FROM SQLITE VERSION:
//  1. provider = "mongodb"  (was "sqlite")
//  2. url uses MONGODB_URI  (was DATABASE_URL pointing to a .db file)
//  3. Every @id field needs @map("_id") @db.ObjectId + @default(auto())
//  4. Every foreign-key scalar (userId, raceId …) needs @db.ObjectId
//  5. relationMode = "prisma" — MongoDB has no FK constraints so Prisma
//     emulates onDelete: Cascade in application code
//  6. String[] / Float[] instead of String @default("[]") JSON blobs
//  7. NO migrations folder — use `prisma db push` to create collections
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mongodb"
  url          = env("MONGODB_URI")
  // Prisma emulates referential actions (cascade, restrict …) in app code
  // because MongoDB has no native foreign-key constraints.
  relationMode = "prisma"
}

// ─── Auth models (required by @next-auth/prisma-adapter) ──────────────────────

model User {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  password      String?          // bcrypt hash — used by CredentialsProvider
  accounts      Account[]
  sessions      Session[]
  watchlists    Watchlist[]
  preferences   UserPreferences?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId           // FK → User._id
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId               // FK → User._id
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth email-magic-link / email-verification tokens
model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ───────────────────────────────────────────────────────────────

model UserPreferences {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @unique @db.ObjectId  // FK → User._id
  favoriteTeam       String?
  favoriteDriver     String?
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(true)
  notifyRaceStart    Boolean  @default(true)
  notifyQualifying   Boolean  @default(true)
  notifyPractice     Boolean  @default(false)
  theme              String   @default("dark")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId                // FK → User._id
  name        String   // max 100 chars — enforced in /api/watchlist validators
  description String?  // max 500 chars — enforced in /api/watchlist validators
  // Native MongoDB arrays — no more JSON.stringify/parse needed
  drivers     String[] @default([])
  teams       String[] @default([])
  races       String[] @default([])
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Race {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  raceId    Int          @unique             // Ergast round number
  season    Int
  round     Int
  name      String
  circuit   String
  date      DateTime
  time      String?
  status    String       @default("scheduled") // scheduled | live | completed
  results   RaceResult[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([season, round])
}

model RaceResult {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  raceId          String   @db.ObjectId            // FK → Race._id
  driverId        String
  position        Int?
  points          Float
  grid            Int?
  laps            Int?
  lapsLed         Int?
  fastestLap      Int?
  fastestLapTime  String?
  fastestLapSpeed String?
  status          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@index([raceId])
  @@index([driverId])
}

model LiveSession {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  raceId       Int
  sessionType  String   // practice | qualifying | race
  driverId     String
  position     Int?
  // Native array — was String @default("[]") JSON blob in SQLite
  laptimes     Float[]  @default([])
  sector1      Float?
  sector2      Float?
  sector3      Float?
  speed        Float?
  tyreCompound String?
  pitStops     Int?
  status       String
  updatedAt    DateTime @updatedAt

  @@index([raceId])
  @@index([sessionType])
}

model SyncLog {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  source           String   // 'openf1' | 'ergast'
  dataType         String   // 'races' | 'results' | 'telemetry'
  status           String   // 'success' | 'failed'
  recordsProcessed Int?
  error            String?
  createdAt        DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}
