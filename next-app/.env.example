# -----------------------------------------------------------------------------
# F1 Analytics Hub - Next.js Environment Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# -----------------------------------------------------------------------------

# -- Database ------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/f1-analytics

# -- Redis ---------------------------------------------------------------------
# Local dev (no password, localhost only):
REDIS_URL=redis://localhost:6379
# Production (password required):
# REDIS_URL=redis://:YOUR_STRONG_PASSWORD@your-redis-host:6379

# -- NextAuth (REQUIRED in production) -----------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_OPENSSL_OUTPUT
# Local: http://localhost:3000 | Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# -- Background jobs (optional, off by default) --------------------------------
# Set true only when Redis is running and you want Bull sync queues in Next.js:
BACKGROUND_JOBS_ENABLED=false

# -- OAuth Providers (optional) ------------------------------------------------
GITHUB_ID=your-github-oauth-app-client-id
GITHUB_SECRET=your-github-oauth-app-client-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# -- External F1 APIs ----------------------------------------------------------
OPENF1_API=https://api.openf1.org/v1
ERGAST_API=https://api.jolpi.ca/ergast/f1

# -- Email (optional) ----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# =============================================================================
# PRODUCTION DEPLOY CHECKLIST
# =============================================================================
# [ ] NEXTAUTH_SECRET  -> openssl rand -base64 32 (unique, never reuse dev secret)
# [ ] NEXTAUTH_URL     -> your public HTTPS URL
# [ ] MONGODB_URI      -> Atlas connection string with strong DB password
# [ ] REDIS_URL        -> must include password (app blocks missing password in prod)
# [ ] OAuth vars       -> only if using GitHub/Google sign-in
# [ ] BACKGROUND_JOBS  -> leave false unless Redis + Bull workers are intended
