# -----------------------------------------------------------------------------
# F1 Analytics Hub - Support Service Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
#
# Auth + MongoDB live in next-app/.env.local (NextAuth + Prisma).
# -----------------------------------------------------------------------------

# -- Server --------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# -- Background polling --------------------------------------------------------
# Set false to stop Jolpica fetches when the support service is idle:
POLLING_ENABLED=true
# Minutes between polls (1-1440):
POLL_INTERVAL_MINUTES=5

# -- Redis ---------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# Local dev - empty only if Redis has no auth and listens on localhost:
REDIS_PASSWORD=
# Production - required when NODE_ENV=production:
# REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# -- Email Service (optional) --------------------------------------------------
EMAIL_USER=your-sender@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_SERVICE=gmail

# -- API -----------------------------------------------------------------------
JOLPICA_API=https://api.jolpi.ca/ergast/f1

# -- CORS ----------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# -- Notifications (optional) --------------------------------------------------
ALERT_EMAIL_ENABLED=false
PUSH_NOTIFICATIONS_ENABLED=false
