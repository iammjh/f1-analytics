# -----------------------------------------------------------------------------
# F1 Analytics Hub — Backend Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# -----------------------------------------------------------------------------

# -- Server --------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# -- Database ------------------------------------------------------------------
# MongoDB Atlas connection string (keep this secret!)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/f1-analytics

# -- JWT -----------------------------------------------------------------------
# Generate a strong secret with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_128_CHAR_RANDOM_HEX_STRING
JWT_EXPIRY=7d

# -- Redis ---------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# -- Email Service (optional) --------------------------------------------------
EMAIL_USER=your-sender@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_SERVICE=gmail

# -- API -----------------------------------------------------------------------
JOLPICA_API=https://api.jolpi.ca/ergast/f1

# -- CORS ----------------------------------------------------------------------
# The frontend origin allowed to call this API (no trailing slash)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# -- Notifications (optional) --------------------------------------------------
ALERT_EMAIL_ENABLED=false
PUSH_NOTIFICATIONS_ENABLED=false
