# Dependencies
**/node_modules/

# Build outputs
.next/
.next-dev/
.next-build/
out/
dist/
build/
coverage/

# Runtime/cache/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.tmp/
tmp/

# Environment and secrets — NEVER commit real credentials
.env
.env.*
.env.local
.env.*.local
!.env.example
!.env.sample

# Docker env overrides (keep these out too)
docker-compose.override.yml

