*.pfx
*.crt
*.cer
*.jks
*.keystore
*.asc
id_rsa
id_rsa.pub
*_rsa
*_dsa
*.ovpn

# Local database / dev data
*.sqlite
*.sqlite3
*.db

# IDE/editor
